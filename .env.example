# ========================================
# Site Club Voile — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ========================================

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="VoileWeb"

# Base de données PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/voile_club

# Payload CMS
PAYLOAD_SECRET=your_payload_secret_here

# Auth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Stockage S3 (Scaleway Object Storage ou AWS S3)
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_BUCKET=voile-club-media
S3_REGION=fr-par
S3_ENDPOINT=https://s3.fr-par.scw.cloud

# Emails transactionnels (Resend ou Brevo)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@voileweb.fr

# Google
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# FFVoile API (nécessite accord Bureau Exécutif)
FFVOILE_API_TOKEN=your_ffvoile_token
FFVOILE_API_BASE_URL=https://api.ffvoile.fr

# Stripe (paiements)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Redis (cache)
REDIS_URL=redis://localhost:6379

# DeepL (traduction automatique, optionnel)
DEEPL_API_KEY=your_deepl_key
